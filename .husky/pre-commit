#!/usr/bin/env sh
# studio-zero pre-commit
# ──────────────────────────────────────────────────────────────────────
# Order (fast → slow):
#   1. Block staged .env / .envrc files outright (allow .env.example).
#   2. Inline secret-scan over staged diff. Pattern set mirrors the
#      CI workflow + the canonical SECRET_PATTERNS in
#      apps/web/lib/sentry-redaction.ts (Cipher's 51-pattern denylist).
#      Coverage extended at M1 Batch 3:
#        AWS access (AKIA) + temp (ASIA)
#        GCP API (AIza…) + service-account JSON marker
#        Azure storage connection-string marker
#        Anthropic (sk-ant-) + admin (sk-ant-admin)
#        OpenAI (sk-…T3BlbkFJ) + project (sk-proj-)
#        OpenRouter (sk-or-v1-) / Replicate (r8_)
#        Stripe sk_/rk_/pk_ live + test + whsec_
#        GitHub PATs ghp_/gho_/ghu_/ghs_/ghr_/github_pat_
#        Slack xoxb-/xoxp-/xapp-/webhook
#        Discord bot / Telegram bot
#        JWTs (eyJ header.payload.signature, 3-segment base64url)
#        SendGrid SG. / Twilio AC/SK / Mailgun key-
#        npm_ / vercel_ / CCI / shpat_ / lin_api_/lin_oauth_
#        ssh-rsa pubkey context / basic-auth-in-URL
#        PEM private-key markers
#        Generic sk- ≥40 chars (legacy OpenAI / Anthropic-ish)
#   3. lint-staged (typecheck + eslint --fix on staged files; now
#      covers BOTH apps/web AND apps/runner per lint-staged.config.js
#      M1 Batch 3 update).
#   4. Conventional-commits hint (informational; commit-msg enforces).
#
# This is the local fast-path. The thorough scan runs in CI via
# .github/workflows/gitleaks.yml. Don't use --no-verify to bypass; if
# the diff is intentional, mark fixture lines and re-run.
# ──────────────────────────────────────────────────────────────────────

set -e

staged_files="$(git diff --cached --name-only --diff-filter=ACMR)"

if [ -n "$staged_files" ]; then
  # ── 1. Block .env* (allow .env.example) ───────────────────────────
  bad_env="$(echo "$staged_files" | grep -E '(^|/)\.env(\.|$)' | grep -Ev '\.example$' || true)"
  if [ -n "$bad_env" ]; then
    echo "✗ pre-commit: refusing to commit .env file(s):"
    echo "$bad_env" | sed 's/^/    /'
    echo "  Move secrets out of the staged file, then re-stage."
    exit 1
  fi

  # ── 2. Regex scan staged content for secret-shaped strings ────────
  # Only look at added (+) lines — context noise produces false positives.
  # Exclude files that carry the CANONICAL pattern set as regex literals.
  diff_added="$(git diff --cached -U0 --diff-filter=ACMR -- \
      ':!apps/web/lib/sentry-redaction.ts' \
      ':!apps/web/lib/sentry-redaction.test.ts' \
      ':!tests/sentry-redaction.test.ts' \
      ':!.github/workflows/ci.yml' \
      ':!.husky/pre-commit' \
      ':!.gitleaks.toml' \
      ':!runner/fixtures/secret-scanner-fixtures/**' \
      ':!runner/fixtures/jwt-tampering-corpus/**' \
      ':!runner/fixtures/prompt-injection-corpus/**' \
      ':!runner/fixtures/secret-exfil-corpus/**' \
      ':!runner/fixtures/sandbox-escape-corpus/**' \
      ':!runner/fixtures/rls-cross-tenant-corpus/**' \
      ':!runner/fixtures/github-webhook-corpus/**' \
      ':!runner/fixtures/ssrf-corpus/**' \
      ':!runner/fixtures/path-traversal-corpus/**' \
      ':!runner/fixtures/stripe-webhook-corpus/**' \
      $staged_files 2>/dev/null \
    | grep -E '^\+[^+]' || true)"

  if [ -n "$diff_added" ]; then
    # ── Cipher 51-pattern denylist (sentry-redaction.ts) mirrored ──
    pattern='AKIA[0-9A-Z]{16}'
    pattern="$pattern"'|ASIA[0-9A-Z]{16}'
    pattern="$pattern"'|AIza[0-9A-Za-z_-]{35}'
    pattern="$pattern"'|"type"\s*:\s*"service_account"'
    pattern="$pattern"'|DefaultEndpointsProtocol=https;AccountName='
    pattern="$pattern"'|sk-ant-[A-Za-z0-9_-]{20,}'
    pattern="$pattern"'|sk-ant-admin[0-9]{2}-[A-Za-z0-9_-]{20,}'
    pattern="$pattern"'|sk-[A-Za-z0-9]{20}T3BlbkFJ[A-Za-z0-9]{20}'
    pattern="$pattern"'|sk-proj-[A-Za-z0-9_-]{20,}'
    pattern="$pattern"'|sk-or-v1-[a-f0-9]{20,}'
    pattern="$pattern"'|r8_[A-Za-z0-9]{36,}'
    pattern="$pattern"'|sk_live_[0-9a-zA-Z]{20,}'
    pattern="$pattern"'|rk_live_[0-9a-zA-Z]{20,}'
    pattern="$pattern"'|pk_live_[0-9a-zA-Z]{20,}'
    pattern="$pattern"'|sk_test_[0-9a-zA-Z]{20,}'
    pattern="$pattern"'|rk_test_[0-9a-zA-Z]{20,}'
    pattern="$pattern"'|whsec_[A-Za-z0-9]{20,}'
    pattern="$pattern"'|ghp_[A-Za-z0-9]{36,}'
    pattern="$pattern"'|gho_[A-Za-z0-9]{36,}'
    pattern="$pattern"'|ghu_[A-Za-z0-9]{36,}'
    pattern="$pattern"'|ghs_[A-Za-z0-9]{36,}'
    pattern="$pattern"'|ghr_[A-Za-z0-9]{36,}'
    pattern="$pattern"'|github_pat_[A-Za-z0-9_]{30,}'
    pattern="$pattern"'|-----BEGIN [A-Z ]*PRIVATE KEY-----'
    pattern="$pattern"'|xoxb-[0-9]{10,}-[0-9]{10,}-[A-Za-z0-9]{20,}'
    pattern="$pattern"'|xoxp-[0-9]{10,}-[0-9]{10,}-[0-9]{10,}-[a-f0-9]{30,}'
    pattern="$pattern"'|xapp-[0-9]+-[A-Z0-9]+-[0-9]+-[a-f0-9]+'
    pattern="$pattern"'|https://hooks\.slack\.com/services/T[A-Z0-9]+/B[A-Z0-9]+/[A-Za-z0-9]{20,}'
    pattern="$pattern"'|[MN][A-Za-z0-9_-]{23}\.[A-Za-z0-9_-]{6,7}\.[A-Za-z0-9_-]{27,}'
    pattern="$pattern"'|[0-9]{8,10}:[A-Za-z0-9_-]{35,}'
    pattern="$pattern"'|eyJ[A-Za-z0-9_-]{8,}\.[A-Za-z0-9_-]{8,}\.[A-Za-z0-9_-]{8,}'
    pattern="$pattern"'|SG\.[A-Za-z0-9_-]{22}\.[A-Za-z0-9_-]{43}'
    pattern="$pattern"'|AC[a-f0-9]{32}'
    pattern="$pattern"'|SK[a-f0-9]{32}'
    pattern="$pattern"'|key-[a-f0-9]{32}'
    pattern="$pattern"'|npm_[A-Za-z0-9]{36,}'
    pattern="$pattern"'|vercel_[A-Za-z0-9]{24,}'
    pattern="$pattern"'|CCI[A-Z0-9]{36,}'
    pattern="$pattern"'|shpat_[a-fA-F0-9]{32}'
    pattern="$pattern"'|lin_api_[A-Za-z0-9]{32,}'
    pattern="$pattern"'|lin_oauth_[A-Za-z0-9]{32,}'
    pattern="$pattern"'|ssh-rsa AAAA[0-9A-Za-z+/]{100,}'
    pattern="$pattern"'|https?://[^[:space:]:/]+:[^[:space:]@]+@[^[:space:]/]+'
    pattern="$pattern"'|sk-[A-Za-z0-9]{40,}'

    hits="$(echo "$diff_added" | grep -nE "$pattern" || true)"
    if [ -n "$hits" ]; then
      echo "✗ pre-commit: staged change contains a secret-shaped string."
      echo "  First match(es):"
      echo "$hits" | head -5 | sed 's/^/    /'
      echo
      echo "  If this is fixture/test data, move it to .env.example or a"
      echo "  scoped fixtures/ path. The gitleaks workflow in CI will also"
      echo "  reject it; fix it here so the PR doesn't need a rewrite."
      echo "  Pattern set mirrors apps/web/lib/sentry-redaction.ts SECRET_PATTERNS (51)."
      exit 1
    fi
  fi
fi

# ── 3. lint-staged (typecheck + eslint --fix on staged files) ──────
# Covers BOTH apps/web AND apps/runner — see lint-staged.config.js
# (M1 Batch 3 update).
npx lint-staged

# ── 4. Conventional-commits hint (informational) ───────────────────
# commit-msg hook enforces this; this is a friendly reminder.
echo "ℹ pre-commit clean. Use a conventional-commits subject:"
echo "    feat: | fix: | chore: | docs: | refactor: | test: | perf: | ci: | build:"

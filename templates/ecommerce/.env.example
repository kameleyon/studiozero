# Shopify Storefront API
NEXT_PUBLIC_SHOPIFY_DOMAIN=your-store.myshopify.com
NEXT_PUBLIC_SHOPIFY_STOREFRONT_TOKEN=your-storefront-access-token

# Stripe (only if running headless checkout — Hydrogen native checkout uses Shopify Pay)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Resend (transactional email — order confirmation, shipping)
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=orders@yourstore.com

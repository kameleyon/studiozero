---
interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
}
const { title, description, pubDate, updatedDate } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site).toString();
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonical} />
    <link rel="alternate" type="application/rss+xml" title="RSS" href={new URL("/rss.xml", Astro.site).toString()} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:type" content="article" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="article:published_time" content={pubDate.toISOString()} />
    {updatedDate && <meta property="article:modified_time" content={updatedDate.toISOString()} />}
    <link rel="stylesheet" href="/src/styles/global.css" />
  </head>
  <body class="bg-white text-zinc-900 antialiased">
    <article class="mx-auto max-w-2xl px-6 py-16 prose prose-zinc">
      <header class="not-prose mb-10">
        <a href="/" class="text-sm text-zinc-500 hover:text-zinc-900">← Home</a>
        <h1 class="mt-4 text-4xl font-bold tracking-tight">{title}</h1>
        <p class="mt-2 text-zinc-600">{description}</p>
        <time datetime={pubDate.toISOString()} class="mt-4 block text-sm text-zinc-500">
          {pubDate.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })}
        </time>
      </header>
      <slot />
    </article>
  </body>
</html>

---
import { getCollection } from "astro:content";

const posts = (await getCollection("blog", ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Studio Zero Blog</title>
    <meta name="description" content="Long-form articles. Replace this description." />
    <link rel="alternate" type="application/rss+xml" title="RSS" href="/rss.xml" />
    <link rel="stylesheet" href="/src/styles/global.css" />
  </head>
  <body class="bg-white text-zinc-900">
    <main class="mx-auto max-w-2xl px-6 py-16">
      <h1 class="text-3xl font-bold tracking-tight">Studio Zero Blog</h1>
      <p class="mt-2 text-zinc-600">A short tagline for this publication.</p>

      <ul class="mt-12 space-y-8">
        {posts.map((post) => (
          <li>
            <a href={`/blog/${post.id}`} class="block group">
              <h2 class="text-xl font-semibold group-hover:text-blue-600">{post.data.title}</h2>
              <p class="mt-1 text-zinc-600">{post.data.description}</p>
              <time datetime={post.data.pubDate.toISOString()} class="mt-2 block text-sm text-zinc-500">
                {post.data.pubDate.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })}
              </time>
            </a>
          </li>
        ))}
      </ul>
    </main>
  </body>
</html>

{
  "name": "@studiozero/cli",
  "version": "0.1.0-m3",
  "description": "Studio Zero CLI — runs audits locally on the customer's machine. Phase 9 M3 Batch 1 (Forge). Pairs with the web app, long-polls for jobs, invokes the customer's local Claude Code installation, and ships a D7-signed verdict back. Source code NEVER leaves the customer's machine (PRD §13.4/§13.5).",
  "type": "module",
  "private": false,
  "license": "UNLICENSED",
  "bin": {
    "studio-zero": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=24.0.0 <25.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "echo 'lint wired in M3 batch 3'"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "picocolors": "^1.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@vitest/coverage-v8": "^2.1.9",
    "tsx": "^4.21.0",
    "typescript": "^5.7.3",
    "vitest": "^2.1.9"
  }
}

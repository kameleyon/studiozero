# Studio Zero — apps/web env example.
# Copy to `.env.local` (gitignored). Production values live in Vercel dashboard.
# Cross-ref: architecture/iac/vercel/env-vars.md

# === Supabase (M0 / M1) ====================================================
# Public URL + anon key are browser-safe (RLS scopes everything).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. Bypasses RLS. NEVER prefix with NEXT_PUBLIC_.
# Used only by Route Handlers in app/api/webhooks/** and admin paths.
SUPABASE_SERVICE_ROLE_KEY=
# Optional: override the Edge Function base URL (defaults to <URL>/functions/v1).
NEXT_PUBLIC_SUPABASE_FN_URL=
# Offline-dev escape hatch — set to "true" to render with mock data + skip
# Supabase Auth. Production builds MUST leave this unset.
NEXT_PUBLIC_USE_AUTH_MOCK=

# === Sentry (M0) ===========================================================
# Public DSN safe for browser bundle (Sentry projects scope by DSN).
NEXT_PUBLIC_SENTRY_DSN=
# Build-time only — sourcemap upload.
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# === PostHog (M0; consent-gated) ===========================================
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# === Stripe (M2) ===========================================================
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
# Stripe webhook secret — used by /api/webhooks/stripe to verify signatures.
STRIPE_WEBHOOK_SECRET=

# === GitHub App (M1) =======================================================
GITHUB_APP_ID=
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=
# RSA private key PEM (multi-line; paste full PEM including BEGIN/END lines).
GITHUB_APP_PRIVATE_KEY=
# Webhook secret — used by /api/webhooks/github to verify X-Hub-Signature-256.
GITHUB_APP_WEBHOOK_SECRET=
# Public slug for install link rendering.
NEXT_PUBLIC_GITHUB_APP_SLUG=studio-zero-audit

# === Resend (M4; transactional email) ======================================
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@studiozero.dev

# === Runtime tags (Vercel-injected; manual override for local dev) =========
NODE_ENV=

{
  "extends": [
    "next/core-web-vitals",
    "next/typescript",
    "plugin:jsx-a11y/recommended",
    "plugin:import/recommended",
    "plugin:import/typescript"
  ],
  "plugins": ["jsx-a11y", "import"],
  "settings": {
    "import/resolver": {
      "typescript": {
        "alwaysTryTypes": true,
        "project": "./tsconfig.json"
      }
    }
  },
  "rules": {
    "react-hooks/exhaustive-deps": "error",

    "jsx-a11y/alt-text": "error",
    "jsx-a11y/anchor-has-content": "error",
    "jsx-a11y/anchor-is-valid": "error",
    "jsx-a11y/aria-props": "error",
    "jsx-a11y/aria-role": "error",
    "jsx-a11y/heading-has-content": "error",
    "jsx-a11y/label-has-associated-control": "error",
    "jsx-a11y/no-redundant-roles": "error",
    "jsx-a11y/role-has-required-aria-props": "error",

    "import/order": [
      "error",
      {
        "groups": [
          "builtin",
          "external",
          "internal",
          ["parent", "sibling", "index"],
          "type"
        ],
        "newlines-between": "always",
        "alphabetize": { "order": "asc", "caseInsensitive": true }
      }
    ],
    "import/no-default-export": "off",
    "import/no-unresolved": "error",

    "no-restricted-imports": [
      "error",
      {
        "patterns": [
          {
            "group": [
              "**/lib/supabase-service",
              "**/lib/supabase-service.ts",
              "../lib/supabase-service",
              "./supabase-service",
              "@/lib/supabase-service"
            ],
            "message": "supabase-service.ts holds the Supabase service-role key and bypasses RLS. It MUST only be imported by app/api/webhooks/** and other server-only Route Handlers — never by client components, Server Components rendered to the browser, or modules that ship to the client bundle. See lib/supabase-service.ts for the boundary policy."
          }
        ]
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "app/**/page.{ts,tsx}",
        "app/**/layout.{ts,tsx}",
        "app/**/loading.{ts,tsx}",
        "app/**/error.{ts,tsx}",
        "app/**/not-found.{ts,tsx}",
        "app/**/route.{ts,tsx}",
        "app/**/template.{ts,tsx}",
        "middleware.ts",
        "next.config.{ts,js,mjs}"
      ],
      "rules": {
        "import/no-default-export": "off"
      }
    },
    {
      "files": [
        "app/api/webhooks/**/route.{ts,tsx}",
        "app/api/admin/**/route.{ts,tsx}",
        "app/api/runs/route.{ts,tsx}",
        "app/api/billing/**/route.{ts,tsx}",
        "app/api/cli/**/route.{ts,tsx}",
        "app/auth/callback/route.{ts,tsx}",
        "instrumentation.ts",
        "lib/cli-auth.ts",
        "lib/cli-manifest-verifier.ts",
        "lib/supabase-service.ts"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
  "ignorePatterns": [
    ".next/",
    "node_modules/",
    "out/",
    "next-env.d.ts",
    "*.tsbuildinfo"
  ]
}

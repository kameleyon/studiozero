        "raw_score_post_round": 70,
        "clamped": false,
        "any_blocker": true,
        "verdict_rule_triggered": "any_blocker",
        "notes": "Score is computed normally (70). The verdict-rule priority list evaluates `any_blocker` FIRST, so verdict is FAIL even though score would otherwise qualify for PASS WITH FIXES. PRD §10 verdict rule."
      },
      "expected_output": { "score": 70, "verdict": "FAIL" }
    },

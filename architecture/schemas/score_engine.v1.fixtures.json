      "label": "empty findings → 100 / PASS (perfect ceiling)",
      "findings_input": [],
      "expected_breakdown": {
        "deduction_total": 0,
        "raw_score_pre_round": 100,
        "raw_score_post_round": 100,
        "clamped": false,
        "any_blocker": false,
        "verdict_rule_triggered": "score_gte_pass_min"
      },
      "expected_output": { "score": 100, "verdict": "PASS" }

# Studio Zero — Environment Variables
# Copy this file to `.env` and fill in real values. `.env` is gitignored.
#
# Load options:
#   - Node 20+:  node --env-file=.env <script>.js
#   - Or export the vars in your shell before running scripts.

# ===========================================================================
# Required for task.js (Google Gemini agent dispatcher)
# Get a key at: https://aistudio.google.com/apikey
# ===========================================================================
STUDIO_ZERO_GOOGLE_API_KEY=

# ===========================================================================
# Optional model overrides
# ===========================================================================
# STUDIO_ZERO_MODEL=gemini-3.1-pro-preview
# STUDIO_ZERO_MODEL_FALLBACK=gemini-2.5-pro

# ===========================================================================
# Optional for task-claude.js (Claude Code dispatcher)
# task-claude.js uses your local `claude` CLI OAuth — no API key needed.
# Override the binary path or model only if you have a non-default setup.
# ===========================================================================
# STUDIO_ZERO_CLAUDE_BIN=claude
# STUDIO_ZERO_MODEL=opus           # or sonnet, haiku, or a full model id
# STUDIO_ZERO_NO_FALLBACK=1        # disable Sonnet fallback when Opus is overloaded

# ===========================================================================
# Optional for audit-run.js
# ===========================================================================
# STUDIO_ZERO_AUDIT_TIMEOUT_MS=600000    # per-reviewer timeout, default 10 min
# STUDIO_ZERO_AUDIT_RUNNER=claude        # claude (default) or gemini
# STUDIO_ZERO_NO_METER=1                 # disable per-audit cost metering

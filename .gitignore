# Secrets — NEVER commit
.env
.env.local
.env.*.local
*.pem
*.key

# Dependencies
node_modules/

# Build artifacts
dist/
build/
.cache/
.next/
coverage/
# V1.5 Forge: re-include the runner's build-agent source dir, which the
# generic `build/` rule above would otherwise hide. These directories
# contain TypeScript SOURCE for the Auto-PR build agents, not compiled
# output (compiled output lives under apps/runner/dist/).
!apps/runner/src/build/
!apps/runner/src/build/**
!apps/runner/tests/build/
!apps/runner/tests/build/**

# apps/web — Next.js build outputs
apps/web/.next/
apps/web/node_modules/
apps/web/.vercel/
apps/web/out/
apps/web/next-env.d.ts
apps/web/*.tsbuildinfo

# apps/runner — Node TS worker build outputs
apps/runner/dist/
apps/runner/node_modules/
apps/runner/coverage/
apps/runner/*.tsbuildinfo

# apps/cli — Node TS binary build outputs (M3 Batch 1)
apps/cli/dist/
apps/cli/node_modules/
apps/cli/coverage/
apps/cli/*.tsbuildinfo

# OS / IDE
.DS_Store
Thumbs.db
.vscode/
.idea/

# Handoff zip + extracted template (re-extract from zip if needed)
*.zip
project-template/

# Logs
*.log
npm-debug.log*
